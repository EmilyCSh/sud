[Unit]
Description=Super User Daemon (Persist auth server) - privilege manager for systemd/Linux
Requires=sud-persist.service

[Socket]
ListenStream=@sud_privilege_manager_persist_socket
Accept=no

[Install]
WantedBy=sockets.target
